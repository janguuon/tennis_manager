# docker-compose 용 환경변수. 복사해서 .env 로 사용 (레포 루트에 위치).
#   cp .env.docker.example .env
# 그리고 아래 두 값을 무작위로 생성해 채우세요:
#   SECRET_KEY:     python3 -c "import secrets; print(secrets.token_hex(32))"
#   SESSION_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=교체하세요_64자리_무작위_hex
SESSION_SECRET=교체하세요_64자리_무작위_hex
# 카카오 공유 JavaScript 키 (카카오 디벨로퍼스 > 플랫폼 키 > JavaScript 키).
# 운영 도메인(https://<도메인>)을 카카오 'JavaScript SDK 도메인'에 등록해야 동작.
KAKAO_JS_KEY=
