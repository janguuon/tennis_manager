[Unit]
Description=Tennis Manager Backend (FastAPI)
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/tennis_manager/backend
EnvironmentFile=/home/ubuntu/tennis_manager/backend/.env
ExecStart=/home/ubuntu/tennis_manager/backend/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 5005
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
