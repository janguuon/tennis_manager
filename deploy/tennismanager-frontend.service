[Unit]
Description=Tennis Manager Frontend (Remix)
After=network.target tennismanager-backend.service

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/teambreaker_manager/frontend
Environment=NODE_ENV=production
Environment=PORT=5555
EnvironmentFile=/home/ubuntu/teambreaker_manager/frontend/.env
ExecStart=/usr/bin/npm run start
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
