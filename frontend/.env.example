# 복사해서 .env 로 사용하세요.
# FastAPI 백엔드 주소
API_URL=http://127.0.0.1:8000
# Remix 세션 쿠키 서명 키 (길고 무작위한 값)
SESSION_SECRET=change_me_to_a_long_random_string
# 카카오 공유(JavaScript 키). 카카오 디벨로퍼스 > 내 앱 > 앱 키 > JavaScript 키.
# 카카오 디벨로퍼스 > 플랫폼 > Web 에 도메인 등록 필요(예: http://localhost:3000, https://<운영도메인>)
KAKAO_JS_KEY=
